{
  "name": "double-meh",
  "version": "1.0.0",
  "description": "HTTP I/O",
  "homepage": "https://github.com/uhop/double-meh#readme",
  "bugs": {
    "url": "https://github.com/uhop/double-meh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/uhop/double-meh.git"
  },
  "license": "BSD-3-Clause",
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (https://www.lazutkin.com/)",
  "type": "module",
  "engines": {
    "node": ">=20.3"
  },
  "sideEffects": [
    "./src/index.js"
  ],
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./*": "./src/*"
  },
  "scripts": {
    "test": "tape6 --flags FO",
    "test:bun": "tape6-bun --flags FO",
    "test:deno": "tape6-deno --flags FO",
    "test:seq": "tape6-seq --flags FO",
    "test:seq:bun": "bun run `tape6-seq --self` --flags FO",
    "test:seq:deno": "deno run -A `tape6-seq --self` --flags FO",
    "test:browser": "tape6-playwright --start-server --flags FO",
    "test:browser:h2": "tape6-playwright --start-server --h2 --flags FO",
    "ts-check": "tsc --noEmit",
    "js-check": "tsc --project tsconfig.check.json",
    "ts-test": "tape6 --flags FO 'tests/test-*.*ts'",
    "ts-test:bun": "tape6-bun --flags FO 'tests/test-*.*ts'",
    "ts-test:deno": "tape6-deno --flags FO 'tests/test-*.*ts'",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "wiki:index": "wiki-search-index --wiki wiki --repo uhop/double-meh --file README.md"
  },
  "keywords": [
    "http",
    "io",
    "lightweight",
    "zero-dependency"
  ],
  "funding": "https://github.com/sponsors/uhop",
  "files": [
    "src",
    "LICENSE",
    "README.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "tape6": {
    "tests": [
      "/tests/test-*.*js"
    ],
    "cli": [
      "/tests/cli/test-*.*js"
    ],
    "browser": [
      "/tests/web/test-*.*js"
    ],
    "importmap": {
      "imports": {
        "tape-six": "/node_modules/tape-six/index.js",
        "tape-six/": "/node_modules/tape-six/src/"
      }
    },
    "server": {
      "plugins": [
        "tests/server/fixtures.js"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "tape-six": "^1.13.0",
    "tape-six-playwright": "^1.2.0",
    "typescript": "^6.0.3",
    "wiki-search-index": "^0.2.0"
  }
}
